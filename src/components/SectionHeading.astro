---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, align = 'left', class: className = '' } = Astro.props;
const wrap = align === 'center' ? 'mx-auto text-center' : '';
---

<div class={`max-w-2xl ${wrap} ${className}`}>
  {
    eyebrow && (
      <p class="text-sm font-semibold tracking-wide text-brand-600 uppercase">{eyebrow}</p>
    )
  }
  <h2 class="mt-2 text-3xl font-bold text-ink sm:text-4xl">{title}</h2>
  <slot />
</div>
