---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { faqs } from '@data/faqs';
---

<section class="border-b border-line bg-surface py-16 lg:py-24">
  <Container size="narrow">
    <SectionHeading eyebrow="FAQ" title="Have some questions?" align="center" class="reveal" />

    <div class="mt-10 space-y-3">
      {
        faqs.map((f, i) => (
          <details
            class="reveal group rounded-2xl border border-line bg-canvas p-5 transition-colors hover:border-brand-200 open:border-brand-300 open:bg-tint/40 open:shadow-card"
            style={`--reveal-delay: ${i * 60}ms`}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-ink">
              {f.question}
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-surface text-brand-600 transition-transform group-open:rotate-45 group-open:bg-brand-500 group-open:text-white">
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" d="M10 4v12M4 10h12" />
                </svg>
              </span>
            </summary>
            <p class="mt-3 text-sm text-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </Container>
</section>
