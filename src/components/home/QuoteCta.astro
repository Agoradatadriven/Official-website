---
import Container from '@components/Container.astro';
import Button from '@components/Button.astro';
import { cta } from '@data/cta';
---

<section class="py-16 lg:py-24">
  <Container>
    <div
      class="overflow-hidden rounded-2xl border border-line bg-tint/60 px-6 py-12 text-center sm:px-12"
    >
      <h2 class="mx-auto max-w-2xl text-3xl font-bold text-ink sm:text-4xl">
        No fixed tiers — just a quote that fits your project
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-muted">
        Pricing depends on scope, complexity, and timeline. After a quick discovery call we'll send
        a custom quote built around your goals.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href={cta.customQuote.href} external size="lg">{cta.customQuote.label}</Button>
        <Button href={cta.joinTeam.href} external variant="secondary" size="lg">
          {cta.joinTeam.label}
        </Button>
      </div>
    </div>
  </Container>
</section>
