---
import Container from '@components/Container.astro';
import Button from '@components/Button.astro';
import { cta } from '@data/cta';
---

<section class="py-16 lg:py-24">
  <Container>
    <div
      class="reveal relative overflow-hidden rounded-3xl border border-brand-200 bg-linear-to-br from-brand-50 via-tint to-surface px-6 py-14 text-center shadow-glow sm:px-12 lg:py-20"
    >
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>
      <div
        class="glow-pulse pointer-events-none absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-brand-300/40 blur-[110px]"
        aria-hidden="true"
      >
      </div>

      <div class="relative">
        <p
          class="mx-auto inline-flex items-center gap-2 rounded-full border border-brand-200 bg-surface/80 px-4 py-1.5 text-xs font-semibold tracking-wide text-brand-700 uppercase backdrop-blur"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500" aria-hidden="true"></span>
          Ready when you are
        </p>
        <h2 class="mx-auto mt-6 max-w-2xl text-3xl font-bold text-ink sm:text-[2.6rem] sm:leading-[1.05]">
          No fixed tiers — just a quote that <span class="text-gradient">fits your project</span>
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-muted">
          Pricing depends on scope, complexity, and timeline. After a quick discovery call we'll send
          a custom quote built around your goals.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <Button href={cta.customQuote.href} external size="lg">{cta.customQuote.label}</Button>
          <Button href={cta.joinTeam.href} external variant="secondary" size="lg">
            {cta.joinTeam.label}
          </Button>
        </div>
        <p class="mt-6 text-xs font-medium tracking-wide text-muted uppercase">
          Top Rated on Upwork · Replies fast · No obligation
        </p>
      </div>
    </div>
  </Container>
</section>
