---
import Container from '@components/Container.astro';

// Real, source-attributed numbers — no invented metrics.
// Sabbath Spa metrics + the Codebasics #9 placement + the verifiable cert count.
interface Stat {
  target: number;
  prefix?: string;
  suffix?: string;
  format?: 'comma';
  label: string;
  sub: string;
}

const stats: Stat[] = [
  {
    target: 100,
    suffix: '%',
    label: 'More social inquiries in 6 weeks',
    sub: 'Sabbath Spa & Wellness',
  },
  {
    target: 40,
    suffix: '%',
    label: 'Increase in actual bookings',
    sub: 'Sabbath Spa & Wellness',
  },
  {
    target: 2459,
    format: 'comma',
    label: 'Entrants in the field',
    sub: '2nd place · Codebasics #9',
  },
  {
    target: 9,
    label: 'Verifiable certifications',
    sub: 'IBM · Google · Meta · Intuit',
  },
];

// Pre-formatted final value so the section reads correctly with JS disabled
// and never flashes "0"; the count-up script resets to 0 on load when JS runs.
const display = (s: Stat) =>
  (s.prefix ?? '') +
  (s.format === 'comma' ? s.target.toLocaleString('en-US') : String(s.target)) +
  (s.suffix ?? '');
---

<section class="surface-dark relative overflow-hidden border-y border-night-600">
  <div class="dot-grid-dark pointer-events-none absolute inset-0 opacity-60"></div>
  <div
    class="glow-pulse pointer-events-none absolute top-1/2 left-1/2 h-72 w-[40rem] max-w-full -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-500/20 blur-[120px]"
  >
  </div>

  <Container class="relative py-16 lg:py-24">
    <div class="max-w-2xl reveal">
      <p class="eyebrow text-brand-300">By the numbers</p>
      <h2 class="mt-4 text-3xl font-bold sm:text-[2.6rem] sm:leading-[1.05]">
        Proof, not promises.
      </h2>
      <p class="mt-3 text-base text-white/65">
        Real outcomes from real engagements — plus a 1st-place, cash-prize finish in operations
        analytics. We measure what we ship.
      </p>
    </div>

    <dl class="mt-12 grid grid-cols-2 gap-x-6 gap-y-10 lg:grid-cols-4 lg:gap-x-8">
      {
        stats.map((s, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 90}ms`}>
            <dt class="sr-only">{s.label}</dt>
            <dd>
              <span
                class="stat-num font-display text-4xl font-bold tracking-tight text-gradient-bright tabular-nums sm:text-5xl lg:text-6xl"
                data-target={s.target}
                data-prefix={s.prefix ?? ''}
                data-suffix={s.suffix ?? ''}
                data-format={s.format ?? ''}
              >
                {display(s)}
              </span>
              <p class="mt-3 font-display text-sm font-semibold text-white">{s.label}</p>
              <p class="mt-1 text-xs text-white/55">{s.sub}</p>
            </dd>
          </div>
        ))
      }
    </dl>
  </Container>
</section>

<script>
  // Count-up the stat numbers when the band scrolls into view (once).
  const nums = document.querySelectorAll<HTMLElement>('.stat-num');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const fmt = (n: number, useComma: boolean) =>
    useComma ? Math.round(n).toLocaleString('en-US') : String(Math.round(n));

  const render = (el: HTMLElement, value: number) => {
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    el.textContent = prefix + fmt(value, el.dataset.format === 'comma') + suffix;
  };

  const run = (el: HTMLElement) => {
    const target = Number(el.dataset.target || '0');
    if (reduce) {
      render(el, target);
      return;
    }
    const duration = 1500;
    let startTs = 0;
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);
    const step = (ts: number) => {
      if (!startTs) startTs = ts;
      const p = Math.min((ts - startTs) / duration, 1);
      render(el, target * ease(p));
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  if (reduce || !('IntersectionObserver' in window)) {
    nums.forEach((el) => render(el, Number(el.dataset.target || '0')));
  } else {
    // JS is running: reset to 0 so the count-up has somewhere to climb from.
    // (No-JS visitors keep the real server-rendered values.)
    nums.forEach((el) => render(el, 0));
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            run(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.4 },
    );
    nums.forEach((el) => io.observe(el));
  }
</script>
