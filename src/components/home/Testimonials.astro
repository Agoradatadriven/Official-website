---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { testimonials } from '@data/testimonials';
---

<section class="border-b border-line bg-surface py-16 lg:py-24">
  <Container>
    <SectionHeading eyebrow="Client results" title="Trusted by clients on Upwork" class="reveal">
      <p class="mt-3 text-muted">Feedback from real engagements on our Upwork agency profile.</p>
    </SectionHeading>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((t, i) => (
          <figure
            class="card-hover reveal relative flex flex-col overflow-hidden rounded-2xl border border-line bg-canvas p-6"
            style={`--reveal-delay: ${(i % 3) * 90}ms`}
          >
            <span
              class="pointer-events-none absolute -top-4 right-5 font-display text-8xl leading-none text-brand-200 select-none"
              aria-hidden="true"
            >
              &rdquo;
            </span>
            <div class="absolute inset-x-0 top-0 h-1 bg-linear-to-r from-brand-500 to-emerald" aria-hidden="true" />
            <div class="relative flex gap-0.5 text-base text-brand-500" aria-hidden="true">
              ★★★★★
            </div>
            <blockquote class="relative mt-4 flex-1 text-body">"{t.quote}"</blockquote>
            <figcaption class="mt-6 flex items-center gap-2 border-t border-line pt-4 font-display text-xs tracking-wider text-muted uppercase">
              <svg class="h-4 w-4 text-brand-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.79 6.8-6.79a1 1 0 0 1 1.4 0Z"
                  clip-rule="evenodd"
                />
              </svg>
              Verified · {t.source}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </Container>
</section>
