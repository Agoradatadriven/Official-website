---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Card from '@components/Card.astro';
import { testimonials } from '@data/testimonials';
---

<section class="border-b border-line bg-surface py-16 lg:py-24">
  <Container>
    <SectionHeading eyebrow="Client results" title="Trusted by clients on Upwork">
      <p class="mt-3 text-muted">
        Feedback from real engagements on our Upwork agency profile.
      </p>
    </SectionHeading>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((t) => (
          <Card as="figure" class="flex flex-col">
            <svg class="h-8 w-8 text-brand-200" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9.5 6C6.5 7.5 5 10 5 13v5h6v-6H8c0-2 1-3.5 3-4.5L9.5 6Zm9 0c-3 1.5-4.5 4-4.5 7v5h6v-6h-3c0-2 1-3.5 3-4.5L18.5 6Z" />
            </svg>
            <blockquote class="mt-3 flex-1 text-body">{t.quote}</blockquote>
            <figcaption class="mt-5 flex items-center gap-2 text-sm font-medium text-muted">
              <span class="grid h-7 w-7 place-items-center rounded-full bg-tint text-xs font-bold text-brand-700">
                ★
              </span>
              {t.source}
            </figcaption>
          </Card>
        ))
      }
    </div>
  </Container>
</section>
