---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';

// Derived from the live "How are we different?" answer — real positioning.
// Laid out as an asymmetric bento: two wide feature cards + two compact cards.
const props = [
  {
    title: 'Actionable insights, not just reports',
    body: 'We translate data into clear decisions and next steps that move marketing performance — not dashboards that gather dust.',
    span: 'sm:col-span-2 lg:col-span-2',
    feature: true,
    // target
    icon: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/>',
  },
  {
    title: 'Deep technical expertise',
    body: 'Hands-on with data, social, and eCommerce analytics — Looker Studio, Google Colab, KPI reporting, and machine learning.',
    span: 'lg:col-span-1',
    feature: false,
    // cpu / chip
    icon: '<rect x="5" y="5" width="14" height="14" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/>',
  },
  {
    title: 'Clear communication',
    body: 'You always know what we are doing and why. We move quickly and keep collaboration simple.',
    span: 'lg:col-span-1',
    feature: false,
    // message bubble
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>',
  },
  {
    title: 'Tailored to your goals',
    body: 'Solutions built around your business objectives and timeline — flexible for short-term sprints or long-term partnerships.',
    span: 'sm:col-span-2 lg:col-span-2',
    feature: true,
    // sliders
    icon: '<line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/><circle cx="9" cy="6" r="2.2" fill="var(--color-surface)"/><circle cx="15" cy="12" r="2.2" fill="var(--color-surface)"/><circle cx="8" cy="18" r="2.2" fill="var(--color-surface)"/>',
  },
];
---

<section class="border-b border-line py-16 lg:py-24">
  <Container>
    <SectionHeading eyebrow="Why Agora" title="What working with us looks like" class="reveal">
      <p class="mt-3 text-muted">
        The strength of a data team, with the clarity and pace of a partner who actually answers.
      </p>
    </SectionHeading>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        props.map((p, i) => (
          <article
            class={`card-hover reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line p-7 ${p.span} ${
              p.feature ? 'bg-tint/45' : 'bg-surface'
            }`}
            style={`--reveal-delay: ${i * 80}ms`}
          >
            {p.feature && (
              <div
                class="pointer-events-none absolute -top-10 -right-10 h-36 w-36 rounded-full bg-brand-300/25 blur-3xl transition-opacity duration-300 group-hover:opacity-100 sm:opacity-70"
                aria-hidden="true"
              />
            )}
            <div class="relative mb-5 grid h-12 w-12 place-items-center rounded-xl bg-linear-to-br from-brand-500 to-emerald text-white shadow-glow-sm">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={p.icon}
              />
            </div>
            <h3 class={`relative font-semibold text-ink ${p.feature ? 'text-xl' : 'text-lg'}`}>
              {p.title}
            </h3>
            <p class={`relative mt-2 text-muted ${p.feature ? 'max-w-md text-base' : 'text-sm'}`}>
              {p.body}
            </p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
